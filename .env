# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=binance_candles_bnb
DB_POOL_LIMIT=3

# Backtest main settings
BACKTEST_SYMBOL=BTCUSDT
BACKTEST_START_TIME=2025-01-01T00:00:00Z
BACKTEST_END_TIME=2025-12-31T23:59:59Z
BACKTEST_INITIAL_BALANCE=1000
BACKTEST_RISK_PER_TRADE=0.01
BACKTEST_LEVERAGE=10
BACKTEST_FEE=0.0004
BACKTEST_PTP_ENABLED=0
BACKTEST_SLIPPAGE=0
BACKTEST_WARMUP_MS=604800000
BACKTEST_DEBUG=1
# Strategy selection
ANALYZE_STRATEGY=STACKED_TREND_STRATEGY
ANALYZE_PROFILE=strict

# STACKED_TREND_STRATEGY knobs
STACKED_MA200_SLOPE_BARS=30
STACKED_ADX1H_MIN=20
STACKED_RSI15_ZONE_LOOKBACK=24
STACKED_BUY_RSI15_DIP_BELOW=42
STACKED_SELL_RSI15_SPIKE_ABOVE=58
STACKED_BUY_RSI5_CONFIRM=53
STACKED_SELL_RSI5_CONFIRM=47
STACKED_SL_ATR_MULT=2.0
STACKED_TP_RR=2.0

# Global MA zone / RSI5 knobs (used by other strategies)
MA_ZONE_PCT=0.01
RSI5_BUY_MIN=50
RSI5_SELL_MAX=50

# Volume filter (used by pullback)
VOLUME_FILTER_ENABLED=1
VOLUME_FILTER_TF=5m
VOLUME_LOOKBACK=20
VOLUME_MULT=1.5
