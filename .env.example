# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=binance_candles

# Binance
# Leave empty for public endpoints
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Default symbols (comma-separated)
SYMBOLS=ETHUSDT

# Demo sizing per symbol
# Format: SYMBOL_QTY_MAP=ETHUSDT:0.1,BTCUSDT:0.001
SYMBOL_QTY_MAP=ETHUSDT:0.1

# Logging
LOG_LEVEL=info
